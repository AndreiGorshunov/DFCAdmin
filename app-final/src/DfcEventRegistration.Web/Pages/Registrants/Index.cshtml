@page
@model DfcEventRegistration.Web.Pages.Registrants.IndexModel
@using DfcEventRegistration.Web.Data
@{
    ViewData["Title"] = "Registrants";
    var isAdmin = User.IsInRole(Auth.Roles.Admin);

    var baseRoute = new Dictionary<string, string>();
    if (!string.IsNullOrWhiteSpace(Model.Q)) baseRoute["Q"] = Model.Q!;
    if (!string.IsNullOrWhiteSpace(Model.Ref)) baseRoute["Ref"] = Model.Ref!;
    if (Model.EventId is Guid ev) baseRoute["EventId"] = ev.ToString();
    if (Model.SessionId is int sid) baseRoute["SessionId"] = sid.ToString();
    if (Model.StartPointId is int spid) baseRoute["StartPointId"] = spid.ToString();
    if (Model.Status is RegistrationStatus st) baseRoute["Status"] = st.ToString();
    if (Model.ParticipantType is ParticipantKind pk) baseRoute["ParticipantType"] = pk.ToString();
    baseRoute["PageSize"] = Model.PageSize.ToString();

    Dictionary<string, string> With(params (string Key, string Value)[] kv)
    {
        var d = new Dictionary<string, string>(baseRoute);
        foreach (var (k, v) in kv) d[k] = v;
        return d;
    }

    var pagerBase = new Dictionary<string, string>(baseRoute);
    if (!string.IsNullOrEmpty(Model.Sort)) pagerBase["Sort"] = Model.Sort!;
    if (!string.IsNullOrEmpty(Model.Dir)) pagerBase["Dir"] = Model.Dir!;
    var exportRoute = new Dictionary<string, string>(pagerBase);

    var sortEmail   = With(("Sort", "email"),     ("Dir", Model.NextDir("email")));
    var sortFirst   = With(("Sort", "firstname"), ("Dir", Model.NextDir("firstname")));
    var sortLast    = With(("Sort", "lastname"),  ("Dir", Model.NextDir("lastname")));
    var sortGroup   = With(("Sort", "groupcode"), ("Dir", Model.NextDir("groupcode")));
    var sortEvent   = With(("Sort", "event"),     ("Dir", Model.NextDir("event")));
    var sortChecked = With(("Sort", "checkedin"), ("Dir", Model.NextDir("checkedin")));

    // Подтверждение для полной выгрузки: текст зависит от того, выбраны ли фильтры.
    bool anyFilter = !string.IsNullOrWhiteSpace(Model.Q)
        || !string.IsNullOrWhiteSpace(Model.Ref)
        || Model.EventId is not null
        || Model.SessionId is not null
        || Model.StartPointId is not null
        || Model.Status is not null
        || Model.ParticipantType is not null;
    var exportConfirm = anyFilter
        ? "Download ALL rows matching the current filters? This may be large and take a while."
        : "No filters are applied — this will download EVERY registrant (potentially millions of rows) and can be very large and slow. Continue?";
}

<h1>Registrants</h1>

@if (!string.IsNullOrEmpty(Model.Notice))
{
    <div class="flash ok">@Model.Notice</div>
}

<form method="get" class="filters filter-bar">
    <div class="filter-row">
        <input type="text" name="Q" value="@Model.Q" placeholder="Email / name / phone…" />
        <input type="text" name="Ref" value="@Model.Ref" class="ref-search" placeholder="Reg. # or QR" title="Exact registration number and/or QR code" />
        <div class="filter-actions">
            <button type="submit">Apply</button>
            <a class="btn-secondary" asp-page="/Registrants/Index">Reset</a>
            <button type="button" id="countBtn" class="btn-secondary">Count ▷</button>
            <details class="export-menu">
                <summary>Export ▾</summary>
                <div class="export-pop">
                    <a asp-page="/Registrants/Index" asp-page-handler="Export"
                       asp-all-route-data="exportRoute" title="Quick export, capped at 100k rows, single sheet">⬇ Excel (≤100k rows)</a>
                    <a asp-page="/Registrants/Index" asp-page-handler="ExportAllCsv"
                       asp-all-route-data="exportRoute" title="All rows, streamed, no limit (recommended)"
                       onclick="return confirm('@exportConfirm');">⬇ Export all — CSV</a>
                    <a asp-page="/Registrants/Index" asp-page-handler="ExportAllXlsx"
                       asp-all-route-data="exportRoute" title="All rows, streamed into one .xlsx (~1M per sheet)"
                       onclick="return confirm('@exportConfirm');">⬇ Export all — Excel</a>
                </div>
            </details>
        </div>
    </div>

    <div class="filter-row controls">
        <label class="filter-field">Event
            <select name="EventId" onchange="this.form.submit()">
                <option value="">— All events —</option>
                @foreach (var e in Model.Events)
                {
                    <option value="@e.Id" selected="@(Model.EventId == e.Id)">@e.Name</option>
                }
            </select>
        </label>

        <label class="filter-field">Session
            <select name="SessionId" onchange="this.form.submit()" title="Select an event to choose a session">
                <option value="">— All sessions —</option>
                @foreach (var s in Model.Sessions)
                {
                    <option value="@s.Id" selected="@(Model.SessionId == s.Id)">@s.Name</option>
                }
            </select>
        </label>

        <label class="filter-field">Start point
            <select name="StartPointId" title="Select a session to choose a start point">
                <option value="">— All start points —</option>
                @foreach (var sp in Model.StartPoints)
                {
                    <option value="@sp.Id" selected="@(Model.StartPointId == sp.Id)">@sp.Name</option>
                }
            </select>
        </label>

        <label class="filter-field">Status
            <select name="Status">
                <option value="">— Any status —</option>
                @foreach (RegistrationStatus s in Enum.GetValues<RegistrationStatus>())
                {
                    <option value="@s" selected="@(Model.Status == s)">@s</option>
                }
            </select>
        </label>

        <label class="filter-field">Participants
            <select name="ParticipantType">
                <option value="">— Adults &amp; children —</option>
                <option value="Adults" selected="@(Model.ParticipantType == ParticipantKind.Adults)">No children</option>
                <option value="Children" selected="@(Model.ParticipantType == ParticipantKind.Children)">With children</option>
            </select>
        </label>

        <label class="filter-field">Page size
            <select name="PageSize">
                @foreach (var n in new[] { 25, 50, 100, 200 })
                {
                    <option value="@n" selected="@(Model.PageSize == n)">@n / page</option>
                }
            </select>
        </label>
    </div>
</form>

<p class="muted" id="countResult" aria-live="polite"></p>

@if (Model.UseKeyset)
{
    <p class="muted">Keyset paging · up to <strong>@Model.PageSize</strong> per page.</p>
}
else
{
    <p class="muted">Found <strong>@Model.Total.ToString("N0")</strong> registrations.</p>
}

<table class="grid">
    <thead>
        <tr>
            <th><a asp-page="/Registrants/Index" asp-all-route-data="sortEmail">Email@(Model.SortIndicator("email"))</a></th>
            <th><a asp-page="/Registrants/Index" asp-all-route-data="sortFirst">First name@(Model.SortIndicator("firstname"))</a></th>
            <th><a asp-page="/Registrants/Index" asp-all-route-data="sortLast">Last name@(Model.SortIndicator("lastname"))</a></th>
            <th>Mobile</th>
            <th><a asp-page="/Registrants/Index" asp-all-route-data="sortGroup">Group@(Model.SortIndicator("groupcode"))</a></th>
            <th><a asp-page="/Registrants/Index" asp-all-route-data="sortEvent">Event@(Model.SortIndicator("event"))</a></th>
            <th><a asp-page="/Registrants/Index" asp-all-route-data="sortChecked">Checked in (venue)@(Model.SortIndicator("checkedin"))</a></th>
            <th class="num">Kids &lt;13</th>
            <th class="num">Kids ≥13</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Rows.Count == 0)
        {
            <tr><td colspan="10" class="muted center">No registrations match the filters.</td></tr>
        }
        @foreach (var r in Model.Rows)
        {
            <tr>
                <td>@r.Email</td>
                <td>@r.FirstName</td>
                <td>@r.LastName</td>
                <td>@r.Mobile</td>
                <td>@r.GroupCode</td>
                <td>@r.EventName</td>
                <td>
                    @if (r.CheckedIn)
                    {
                        <span class="badge yes">Yes</span>
                    }
                    else
                    {
                        <span class="badge no">No</span>
                    }
                </td>
                <td class="num">@r.KidsBelow13</td>
                <td class="num">@r.KidsAbove13</td>
                <td>@if (isAdmin) { <a asp-page="/Registrants/Edit" asp-route-id="@r.RegistrationId">Edit</a> } else { <a asp-page="/Registrants/Details" asp-route-id="@r.RegistrationId">View</a> }</td>
            </tr>
        }
    </tbody>
</table>

@if (Model.UseKeyset)
{
    <div class="pager">
        @if (!Model.IsFirstPage)
        {
            <a asp-page="/Registrants/Index" asp-all-route-data="pagerBase">« First</a>
        }
        @if (Model.HasNext)
        {
            var nextRoute = new Dictionary<string, string>(pagerBase)
            {
                ["AfterLastName"] = Model.NextLastName ?? "",
                ["AfterId"] = (Model.NextId ?? 0).ToString()
            };
            <a asp-page="/Registrants/Index" asp-all-route-data="nextRoute">Next ›</a>
        }
    </div>
}
else if (Model.TotalPages > 1)
{
    var prevRoute = new Dictionary<string, string>(pagerBase) { ["PageNo"] = (Model.PageNo - 1).ToString() };
    var nextRoute = new Dictionary<string, string>(pagerBase) { ["PageNo"] = (Model.PageNo + 1).ToString() };
    <div class="pager">
        @if (Model.PageNo > 1)
        {
            <a asp-page="/Registrants/Index" asp-all-route-data="prevRoute">‹ Prev</a>
        }
        <span>Page @Model.PageNo of @Model.TotalPages</span>
        @if (Model.PageNo < Model.TotalPages)
        {
            <a asp-page="/Registrants/Index" asp-all-route-data="nextRoute">Next ›</a>
        }
    </div>
}

<script>
    document.getElementById('countBtn').addEventListener('click', async function () {
        var form = document.querySelector('form.filters');
        var params = new URLSearchParams();
        params.set('handler', 'Count');

        // Берём ТЕКУЩИЕ значения формы (даже если фильтр ещё не "применён").
        var q = form.querySelector('[name="Q"]').value.trim();
        var refv = form.querySelector('[name="Ref"]').value.trim();
        var eventId = form.querySelector('[name="EventId"]').value;
        var status = form.querySelector('[name="Status"]').value;
        var ptype = form.querySelector('[name="ParticipantType"]').value;
        var sessionId = form.querySelector('[name="SessionId"]').value;
        var startPointId = form.querySelector('[name="StartPointId"]').value;
        if (q) params.set('Q', q);
        if (refv) params.set('Ref', refv);
        if (eventId) params.set('EventId', eventId);
        if (sessionId) params.set('SessionId', sessionId);
        if (startPointId) params.set('StartPointId', startPointId);
        if (status) params.set('Status', status);
        if (ptype) params.set('ParticipantType', ptype);

        var out = document.getElementById('countResult');
        out.textContent = 'Counting…';
        try {
            var r = await fetch('?' + params.toString(), { headers: { 'Accept': 'application/json' } });
            if (!r.ok) throw new Error('HTTP ' + r.status);
            var n = await r.json();
            out.textContent = n.toLocaleString() + ' registrations match the current filters.';
        } catch (e) {
            out.textContent = 'Count failed — try again.';
        }
    });
</script>
