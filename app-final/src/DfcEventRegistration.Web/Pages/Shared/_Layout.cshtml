@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@{
    // Подсветка окружения: в Production показываем метку PROD и приглушённый фон,
    // чтобы случайно не принять прод за локальный стенд.
    var isProd = string.Equals(Env.EnvironmentName, "Production", StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · DFC 2026 Admin</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/forms.css" asp-append-version="true" />
    <style>
        .topbar { display: flex; align-items: center; gap: 1rem; }
        .userbox { margin-left: auto; display: flex; align-items: center; gap: .5rem; font-size: .9rem; }
        .userbox .role { opacity: .7; }
        .userbox form { margin: 0; }

        /* Маркер окружения Production — заметно, но не броско. */
        .topbar.env-prod { background: #fbf3e4; box-shadow: inset 0 -2px 0 #d8a23a; }
        .env-badge {
            font-size: .68rem; font-weight: 700; letter-spacing: .06em;
            padding: .1rem .4rem; border-radius: 4px; text-transform: uppercase;
            color: #8a4b00; background: rgba(217, 119, 6, .16); border: 1px solid rgba(217, 119, 6, .4);
        }
    </style>
</head>
<body>
    <header class="topbar@(isProd ? " env-prod" : "")">
        <span class="brand">DFC 2026 · Admin</span>
        @if (isProd)
        {
            <span class="env-badge" title="Production environment">PROD</span>
        }
        @if (User.Identity?.IsAuthenticated == true)
        {
            var isAdmin = User.IsInRole(Auth.Roles.Admin);
            var isSteward = User.IsInRole(Auth.Roles.Steward);
            var isPartner = User.IsInRole(Auth.Roles.Partner);
            var canCheckIn = isAdmin || isSteward;
            var roleName = isAdmin ? Auth.Roles.Admin
                         : isSteward ? Auth.Roles.Steward
                         : isPartner ? Auth.Roles.Partner : "—";
            <nav>
                <a asp-page="/Registrants/Index">Registrants</a>
                @if (!isSteward)
                {
                    <a asp-page="/Users/Index">Users</a>
                    <a asp-page="/Children/Index">Children</a>
                }
                @if (isAdmin)
                {
                    <a asp-page="/Events/Index">Events</a>
                }
                @if (canCheckIn)
                {
                    <a asp-page="/CheckIn/Index">Check-in</a>
                }
                @if (!isSteward)
                {
                    <a asp-page="/Reports/Tshirts">T-shirt report</a>
                }
                @if (isAdmin)
                {
                    <a asp-page="/Admins/Index">Admins</a>
                    <a asp-page="/Audit/Index">Audit</a>
                }
            </nav>
            <span class="userbox">
                <span class="who">@User.Identity!.Name</span>
                <span class="role">(@roleName)</span>
                <form method="post" asp-page="/Account/Logout">
                    <button type="submit" class="btn-link">Sign out</button>
                </form>
            </span>
        }
    </header>
    <main class="container">
        @RenderBody()
    </main>
</body>
</html>
