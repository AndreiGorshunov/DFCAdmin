<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · DFC 2026 Admin</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/forms.css" asp-append-version="true" />
    <style>
        .topbar { display: flex; align-items: center; gap: 1rem; }
        .userbox { margin-left: auto; display: flex; align-items: center; gap: .5rem; font-size: .9rem; }
        .userbox .role { opacity: .7; }
        .userbox form { margin: 0; }
    </style>
</head>
<body>
    <header class="topbar">
        <span class="brand">DFC 2026 · Admin</span>
        @if (User.Identity?.IsAuthenticated == true)
        {
            var isAdmin = User.IsInRole(Auth.Roles.Admin);
            <nav>
                <a asp-page="/Registrants/Index">Registrants</a>
                <a asp-page="/Users/Index">Users</a>
                <a asp-page="/Children/Index">Children</a>
                @if (isAdmin)
                {
                    <a asp-page="/Events/Index">Events</a>
                }
                <a asp-page="/Reports/Tshirts">T-shirt report</a>
            </nav>
            <span class="userbox">
                <span class="who">@User.Identity!.Name</span>
                <span class="role">(@(isAdmin ? Auth.Roles.Admin : Auth.Roles.Partner))</span>
                <form method="post" asp-page="/Account/Logout">
                    <button type="submit" class="btn-link">Sign out</button>
                </form>
            </span>
        }
    </header>
    <main class="container">
        @RenderBody()
    </main>
</body>
</html>
