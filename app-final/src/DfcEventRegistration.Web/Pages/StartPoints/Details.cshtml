@page
@model DfcEventRegistration.Web.Pages.StartPoints.DetailsModel
@using DfcEventRegistration.Web.Data
@{
    ViewData["Title"] = "Start point registrants";

    var baseRoute = new Dictionary<string, string> { ["startPointId"] = Model.StartPointId.ToString() };
    if (!string.IsNullOrWhiteSpace(Model.Q)) baseRoute["Q"] = Model.Q!;
    if (Model.Status is RegistrationStatus st) baseRoute["Status"] = st.ToString();
    baseRoute["PageSize"] = Model.PageSize.ToString();
}

<p class="muted"><a asp-page="/StartPoints/Index" asp-route-sessionId="@Model.SessionId">‹ Back to start points</a></p>
<h1>@Model.StartPointName <span class="muted small">— @Model.SessionName · @Model.EventName</span></h1>

<div class="card">
    <table class="grid">
        <tbody>
            <tr><th>Time</th><td>@(Model.StartTime?.ToString("HH\\:mm") ?? "—")@(Model.EndTime is null ? "" : "–" + Model.EndTime.Value.ToString("HH\\:mm"))</td></tr>
            <tr><th>Capacity</th><td>@(Model.Capacity?.ToString("N0") ?? "— (unlimited)")</td></tr>
            <tr>
                <th>Assigned</th>
                <td>
                    @if (Model.Capacity is null)
                    {
                        <text>@Model.Occupied.ToString("N0") (unlimited)</text>
                    }
                    else if (Model.IsFull)
                    {
                        <text>@Model.Occupied.ToString("N0") / @Model.Capacity.Value.ToString("N0") </text>
                        <span class="badge full">Full</span>
                    }
                    else
                    {
                        <text>@Model.Occupied.ToString("N0") / @Model.Capacity.Value.ToString("N0") · @Model.Free!.Value.ToString("N0") free</text>
                    }
                </td>
            </tr>
            <tr><th>Checked in here</th><td>@Model.CheckedInHereCount.ToString("N0") / @Model.Occupied.ToString("N0")</td></tr>
        </tbody>
    </table>
</div>

<form method="get" class="filters">
    <input type="hidden" name="startPointId" value="@Model.StartPointId" />
    <input type="text" name="Q" value="@Model.Q" placeholder="Email / name / phone…" />
    <select name="Status">
        <option value="">— Any status —</option>
        @foreach (RegistrationStatus s in Enum.GetValues<RegistrationStatus>())
        {
            <option value="@s" selected="@(Model.Status == s)">@s</option>
        }
    </select>
    <select name="PageSize">
        @foreach (var n in new[] { 25, 50, 100, 200 })
        {
            <option value="@n" selected="@(Model.PageSize == n)">@n / page</option>
        }
    </select>
    <button type="submit">Apply</button>
    <a class="btn-secondary" asp-page="/StartPoints/Details" asp-route-startPointId="@Model.StartPointId">Reset</a>
</form>

<p class="muted">Found <strong>@Model.Total.ToString("N0")</strong> registrant(s) at this start point.</p>

<table class="grid">
    <thead>
        <tr><th>Last name</th><th>First name</th><th>Email</th><th>Checked in here</th><th>Reg. status</th><th></th></tr>
    </thead>
    <tbody>
        @if (Model.Rows.Count == 0)
        {
            <tr><td colspan="6" class="muted center">No registrants assigned to this start point match the filters.</td></tr>
        }
        @foreach (var r in Model.Rows)
        {
            <tr>
                <td>@r.LastName</td>
                <td>@r.FirstName</td>
                <td>@r.Email</td>
                <td>
                    @if (r.CheckedInHere)
                    {
                        <span class="badge yes">Yes</span>
                        @if (r.CheckInTime is not null) { <span class="muted small"> @r.CheckInTime.Value.ToString("HH:mm")</span> }
                    }
                    else
                    {
                        <span class="badge no">No</span>
                    }
                </td>
                <td>@r.Status</td>
                <td><a asp-page="/Registrants/Edit" asp-route-id="@r.RegistrationId">Edit</a></td>
            </tr>
        }
    </tbody>
</table>

@if (Model.TotalPages > 1)
{
    var prevRoute = new Dictionary<string, string>(baseRoute) { ["PageNo"] = (Model.PageNo - 1).ToString() };
    var nextRoute = new Dictionary<string, string>(baseRoute) { ["PageNo"] = (Model.PageNo + 1).ToString() };
    <div class="pager">
        @if (Model.PageNo > 1)
        {
            <a asp-page="/StartPoints/Details" asp-all-route-data="prevRoute">‹ Prev</a>
        }
        <span>Page @Model.PageNo of @Model.TotalPages</span>
        @if (Model.PageNo < Model.TotalPages)
        {
            <a asp-page="/StartPoints/Details" asp-all-route-data="nextRoute">Next ›</a>
        }
    </div>
}
