@page
@model DfcEventRegistration.Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Sign in";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign in · DFC 2026 Backoffice</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/forms.css" asp-append-version="true" />
</head>
<body>
    <main class="container" style="max-width:440px;margin:10vh auto;">
        <h1>DFC 2026 · Backoffice</h1>

        @if (Model.DevMode)
        {
            <div class="card">
                <h2>Developer sign-in</h2>
                <p class="muted small">No identity provider is wired yet. Sign in as a seeded user to test roles — the role comes from the AdminUsers table.</p>

                <div asp-validation-summary="All"></div>

                @if (Model.KnownUsers.Count == 0)
                {
                    <p class="muted">No active access records found. Run <code>sql/05_auth.sql</code> to seed users.</p>
                }
                else
                {
                    <form method="post" asp-page="/Account/Login">
                        <input type="hidden" asp-for="ReturnUrl" />
                        <label>Sign in as
                            <select asp-for="Email">
                                @foreach (var u in Model.KnownUsers)
                                {
                                    <option value="@u.Email">@u.Email — @u.Role@(string.IsNullOrEmpty(u.DisplayName) ? "" : $" ({u.DisplayName})")</option>
                                }
                            </select>
                        </label>
                        <div class="actions">
                            <button type="submit" class="btn-primary">Sign in (dev)</button>
                        </div>
                    </form>
                }
            </div>
        }
        else
        {
            <div class="card">
                <h2>Sign-in unavailable</h2>
                <p class="muted">No identity provider is configured yet. Please contact the administrator.</p>
            </div>
        }
    </main>
</body>
</html>
