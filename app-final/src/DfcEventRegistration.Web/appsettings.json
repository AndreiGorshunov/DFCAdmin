{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",

  // Строка подключения НЕ хранится в этом (коммитимом) файле — здесь пустой плейсхолдер.
  // Значение задаётся по окружению (последний источник побеждает):
  //   * локально (dev) -> appsettings.Development.json (в .gitignore) или dotnet user-secrets;
  //   * сервер/VM (prod) -> переменная окружения ConnectionStrings__Default
  //     (двойное подчёркивание = разделитель секций), либо appsettings.Production.json,
  //     лежащий ТОЛЬКО на сервере (не в репо).
  // Пример (SQL-auth) для VM:
  //   ConnectionStrings__Default="Server=SQLHOST;Database=dfc.EventRegistration;User Id=app;Password=***;Encrypt=True;TrustServerCertificate=True;"
  "ConnectionStrings": {
    "Default": ""
  },

  // Stock-а нет в схеме БД — задаём остатки футболок здесь (placeholder).
  // Если поле null/отсутствует — в отчёте показываем "—".
  "TshirtStock": {
    "XS": 500,
    "S": 1500,
    "M": 3000,
    "L": 3000,
    "XL": 1500,
    "XXL": 500
  },

  // Защита от выгрузки миллиона строк в Excel одним кликом.
  "Export": {
    "MaxRows": 100000,
    // Таймаут SQL для ПОЛНОЙ потоковой выгрузки (CSV / multi-sheet XLSX).
    // 0 = без лимита (осознанно: админ-выгрузка может идти долго).
    "CommandTimeoutSeconds": 0
  },

  // Поиск регистрантов:
  //   true  -> full-text CONTAINS по Users (требует FTS-индекса из 04_keyset_indexes.sql);
  //   false -> токенизированный LIKE (работает без FTS-фичи на сервере).
  // В ветке fts держим true; если на сервере FTS недоступен — переключить в false.
  "Search": {
    "UseFullText": true
  },

  // Аутентификация. Роли хранятся в таблице dbo.AdminUsers (не в конфиге).
  // Секция Oidc — заготовка под реальный IdP (см. Auth/OidcAuthentication.cs); пока Enabled=false.
  // ClientSecret в проде хранить в user-secrets / переменных окружения, НЕ в этом файле.
  "Auth": {
    "Oidc": {
      "Enabled": false,
      "Authority": "",
      "ClientId": "",
      "ClientSecret": ""
    }
  }
}
