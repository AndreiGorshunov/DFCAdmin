{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    // Имя БД содержит точку — в строке подключения это допустимо как есть.
    // Windows-auth (по умолчанию):
    //"Default": "Server=localhost;Database=dfc.EventRegistration;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=False;"
    // SQL-auth (раскомментируй и подставь свои значения):
    "Default": "Server=localhost;Database=dfc.EventRegistration;Integrated Security=True;TrustServerCertificate=True;"
  },

  // Stock-а нет в схеме БД — задаём остатки футболок здесь (placeholder).
  // Если поле null/отсутствует — в отчёте показываем "—".
  "TshirtStock": {
    "XS": 500,
    "S": 1500,
    "M": 3000,
    "L": 3000,
    "XL": 1500,
    "XXL": 500
  },

  // Защита от выгрузки миллиона строк в Excel одним кликом.
  "Export": {
    "MaxRows": 100000
  }
}
